# Environment Variables — BharatLCL
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bharatlcl?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ULIP API (Government Logistics Platform)
ULIP_API_KEY=your_ulip_api_key
ULIP_BASE_URL=https://ulip.gov.in/api/v1

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Razorpay (Payment Gateway — Sandbox)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
