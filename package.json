{
  "name": "bharatlcl",
  "version": "1.0.0",
  "description": "BharatLCL — Digital Logistics Marketplace for Indian MSMEs. Real-time LCL freight consolidation platform for the Jaipur-Mundra export corridor.",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "dev:server": "nodemon src/main.js",
    "dev:client": "npm --prefix src/client run dev",
    "dev": "npm run dev:client",
    "build": "npm --prefix src/client run build",
    "build:start": "npm run build && npm start",
    "test": "jest --watchAll=false",
    "test:unit": "jest tests/unit --watchAll=false",
    "test:integration": "jest tests/integration --watchAll=false",
    "test:coverage": "jest --coverage --watchAll=false",
    "lint": "eslint src/ --ext .js,.jsx"
  },
  "keywords": [
    "logistics",
    "LCL",
    "MSME",
    "India",
    "freight",
    "marketplace",
    "MERN",
    "ULIP"
  ],
  "author": "BharatLCL Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
